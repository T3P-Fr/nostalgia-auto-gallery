# Cette clé protège les opérations de gestion dans l'espace administrateur.
ADMIN_KEY=corentin
PORT=3001

# --- Emails (Resend) ---------------------------------------------------------
# Notifications automatiques à chaque réservation/demande : accusé au client (si
# email fourni) + notification au gérant. Sans RESEND_API_KEY, l'envoi est ignoré
# silencieusement (la réservation fonctionne quand même).
# Clé API Resend (https://resend.com → API Keys).
RESEND_API_KEY=
# Expéditeur — DOIT être sur un domaine vérifié dans Resend
# (ex. "Nostalgia Gallery Auto <contact@votre-domaine.fr>"). En dev/test,
# "onboarding@resend.dev" fonctionne mais n'envoie qu'à votre propre adresse.
MAIL_FROM=Nostalgia Gallery Auto <onboarding@resend.dev>
# Adresse qui reçoit les notifications internes (Corentin).
MAIL_TO_OWNER=
