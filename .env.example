# Cette clé protège les opérations de gestion dans l'espace administrateur.
ADMIN_KEY=corentin
PORT=3001

# --- Emails (SMTP du domaine, cPanel / o2switch) -----------------------------
# Notifications automatiques à chaque réservation/demande : accusé au client (si
# email fourni) + notification au gérant. Sans configuration SMTP complète,
# l'envoi est ignoré silencieusement (la réservation fonctionne quand même).
SMTP_HOST=nostalgia.caef.fr
# 465 = SSL/TLS (recommandé) ; 587 = STARTTLS.
SMTP_PORT=465
SMTP_USER=corentin@nostalgia.caef.fr
# Mot de passe du compte mail.
SMTP_PASS=
# Expéditeur affiché (doit correspondre au compte authentifié).
MAIL_FROM=Nostalgia Auto Gallery <corentin@nostalgia.caef.fr>
# Adresse qui reçoit les notifications internes (Corentin).
MAIL_TO_OWNER=
