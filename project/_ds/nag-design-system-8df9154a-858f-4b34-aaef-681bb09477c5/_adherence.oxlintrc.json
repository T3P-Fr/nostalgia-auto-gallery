{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/automotive/**",
              "components/core/**",
              "components/forms/**",
              "ui_kits/vitrine/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Saira Condensed|Saira|Spline Sans Mono))/i]",
        "message": "Font not provided by the design system. Available: Saira Condensed, Saira, Spline Sans Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|outline|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, outline, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:red|sun|ok|warn|info|neutral|ink)$/]",
        "message": "<Badge> tone must be one of 'red' | 'sun' | 'ok' | 'warn' | 'info' | 'neutral' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|block|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, block, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|chrome|ink|ghost|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'chrome' | 'ink' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|hover|pad|as|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: accent, hover, pad, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|tick|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, tick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|muted|on-dark)$/]",
        "message": "<Eyebrow> tone must be one of 'brand' | 'muted' | 'on-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|prefix|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, error, prefix."
      },
      {
        "selector": "JSXOpeningElement[name.name='GearRule'] > JSXAttribute > JSXIdentifier[name!=/^(?:mark|tone|key|ref|className|style|children)$/]",
        "message": "<GearRule> doesn't accept that prop. Declared props: mark, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='GearRule'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|dark)$/]",
        "message": "<GearRule> tone must be one of 'default' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlateTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dept|region|size|key|ref|className|style|children)$/]",
        "message": "<PlateTag> doesn't accept that prop. Declared props: children, dept, region, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlateTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PlateTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|icon|description|priceFrom|bullets|dark|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: index, title, icon, description, priceFrom, bullets, dark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spec'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<Spec> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|suffix|accent|align|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, suffix, accent, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<Stat> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onRemove|icon|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: selected, onRemove, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='VehicleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|subtitle|year|km|gearbox|fuel|price|status|statusTone|onView|key|ref|className|style|children)$/]",
        "message": "<VehicleCard> doesn't accept that prop. Declared props: image, title, subtitle, year, km, gearbox, fuel, price, status, statusTone, onView."
      },
      {
        "selector": "JSXOpeningElement[name.name='VehicleCard'] > JSXAttribute[name.name='statusTone'] > Literal[value!=/^(?:ok|red|sun|warn|info|neutral)$/]",
        "message": "<VehicleCard> statusTone must be one of 'ok' | 'red' | 'sun' | 'warn' | 'info' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
